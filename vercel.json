{
  "version": 2,
  "name": "zarii-ai",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/server.js" },
    { "source": "/webhook", "destination": "backend/server.js" },
    { "source": "/webhooks/(.*)", "destination": "backend/server.js" },
    { "source": "/uploads/(.*)", "destination": "backend/server.js" },
    { "source": "/diseases(.*)", "destination": "backend/server.js" },
    { "source": "/pesticides(.*)", "destination": "backend/server.js" },
    { "source": "/farmers(.*)", "destination": "backend/server.js" },
    { "source": "/learn(.*)", "destination": "backend/server.js" },
    { "source": "/sitemap.xml", "destination": "backend/server.js" },
    { "source": "/robots.txt", "destination": "backend/server.js" },
    { "source": "/admin", "destination": "/index.html" }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(diseases|pesticides|farmers|learn|sitemap\\.xml|robots\\.txt)(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
